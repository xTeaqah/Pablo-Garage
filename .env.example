# Local Docker example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pablo_garage"
# Neon/Railway: use the connection string from your provider dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
DVLA_API_KEY="your-dvla-api-key-here"

# Auth — required for sign-in (generate with: openssl rand -base64 48)
AUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Initial admin credentials (hashed on first login or seed). Change via Settings after setup.
ADMIN_USERNAME="Pablo"
ADMIN_PASSWORD="change-me-before-deploy"

# Set to "true" only when intentionally resetting admin password via seed
# SEED_RESET_AUTH="false"
